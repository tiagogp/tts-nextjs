{"nodes": [{"id": "_agents_skills_review_animations_skill_review_animations", "label": "Review Animations Skill", "file_type": "document", "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default to flagging; approval is earned. A transition that runs but feels sluggish, lands from the wrong origin, or drops frames is a regression, not a pass."}, {"id": "_agents_skills_review_animations_skill_ten_standards", "label": "Ten Non-Negotiable Animation Standards", "file_type": "rationale", "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## The Ten Non-Negotiable Standards", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every animation in a diff is measured against justified motion, frequency-appropriateness, responsive easing, sub-300ms budgets, origin correctness, interruptibility, GPU-only properties, accessibility, asymmetric timing, and cohesion; a violation is a finding."}, {"id": "_agents_skills_review_animations_skill_escalation_triggers", "label": "Aggressive Escalation Triggers", "file_type": "rationale", "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## Aggressive Escalation Triggers", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Flag-on-sight patterns (transition: all, scale(0), ease-in on UI, layout-property animation, ungated hover) that are always findings regardless of context."}, {"id": "_agents_skills_review_animations_skill_remedial_hierarchy", "label": "Remedial Preference Hierarchy", "file_type": "rationale", "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## Remedial Preference Hierarchy", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prefer earlier moves over later ones: delete the animation before reducing it, fix easing before origin, make it interruptible before polishing \u2014 removing motion is safer than tuning it."}, {"id": "_agents_skills_review_animations_skill_emil_kowalski_philosophy", "label": "Emil Kowalski Animation Philosophy (animations.dev)", "file_type": "concept", "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": null, "source_url": "https://animations.dev/", "captured_at": null, "author": "Emil Kowalski", "contributor": null}], "edges": [{"source": "_agents_skills_review_animations_skill_review_animations", "target": "_agents_skills_review_animations_standards_animation_standards", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "For the full rule catalog ... see STANDARDS.md", "weight": 1.0}, {"source": "_agents_skills_review_animations_skill_review_animations", "target": "_agents_skills_review_animations_skill_emil_kowalski_philosophy", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## Operating Posture", "weight": 1.0}, {"source": "_agents_skills_review_animations_skill_review_animations", "target": "_agents_skills_review_animations_skill_ten_standards", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## The Ten Non-Negotiable Standards", "weight": 1.0}, {"source": "_agents_skills_review_animations_skill_review_animations", "target": "_agents_skills_review_animations_skill_escalation_triggers", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/SKILL.md", "source_location": "## Aggressive Escalation Triggers", "weight": 1.0}, {"source": "_agents_skills_review_animations_skill_review_animations", "target": "_a