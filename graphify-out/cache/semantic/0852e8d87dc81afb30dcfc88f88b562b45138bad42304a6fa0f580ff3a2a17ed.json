{"nodes": [{"id": "_agents_skills_review_animations_standards_animation_standards", "label": "Animation Standards Reference", "file_type": "document", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_agents_skills_review_animations_standards_frequency_table", "label": "Animation Frequency Table", "file_type": "rationale", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Should it animate? (frequency table)", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The more often an action is seen, the less it should animate; keyboard-initiated actions never animate because they repeat hundreds of times daily and animation makes them feel slow and disconnected."}, {"id": "_agents_skills_review_animations_standards_easing_rules", "label": "Easing Decision Rules", "file_type": "rationale", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Easing", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ease-out for enter/exit because it starts fast and feels responsive; ease-in is banned on UI because it delays the exact moment the user is watching. Built-in CSS easings are too weak \u2014 use strong custom cubic-beziers."}, {"id": "_agents_skills_review_animations_standards_duration_budgets", "label": "Per-Element Duration Budgets", "file_type": "concept", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Duration", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "UI animations stay under 300ms: button press 100-160ms, tooltips 125-200ms, dropdowns 150-250ms, modals/drawers 200-500ms; faster motion makes the interface feel faster at the same actual speed."}, {"id": "_agents_skills_review_animations_standards_spring_config", "label": "Spring Animation Configuration", "file_type": "concept", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Springs", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Springs settle on physics parameters rather than fixed duration and maintain velocity when interrupted (keyframes restart from zero), so they suit gestures users may reverse mid-motion; keep bounce subtle (0.1-0.3)."}, {"id": "_agents_skills_review_animations_standards_interruptibility", "label": "Interruptibility (Transitions vs Keyframes)", "file_type": "rationale", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Interruptibility", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CSS transitions can be retargeted mid-animation while keyframes restart from zero, so anything triggered rapidly (toasts, toggles) must use transitions or springs; @starting-style enables JS-free entry."}, {"id": "_agents_skills_review_animations_standards_gpu_only_rule", "label": "GPU-Only Property Rule", "file_type": "rationale", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Performance", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only transform and opacity skip layout/paint and run on the GPU; Framer Motion x/y/scale shorthands run on the main thread via rAF and drop frames under load \u2014 use the full transform string; never drive child transforms via a parent CSS variable (style recalc storm)."}, {"id": "_agents_skills_review_animations_standards_reduced_motion", "label": "Reduced Motion Accessibility", "file_type": "concept", "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Accessibility", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reduced motion means fewer and gentler animations, not zero \u2014 keep opacity/color transitions that aid comprehension, drop movement; gate hover motion behind (hover: hover) and (pointer: fine) because touch fires false hovers on tap."}], "edges": [{"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_skill_emil_kowalski_philosophy", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "Distilled from Emil Kowalski's design engineering philosophy", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_frequency_table", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Should it animate? (frequency table)", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_easing_rules", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Easing", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_duration_budgets", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Duration", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_spring_config", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Springs", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_interruptibility", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Interruptibility", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_gpu_only_rule", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Performance", "weight": 1.0}, {"source": "_agents_skills_review_animations_standards_animation_standards", "target": "_agents_skills_review_animations_standards_reduced_motion", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".agents/skills/review-animations/STANDARDS.md", "source_location": "## Accessibility", "weight": 1.0}], "hyperedges": []}