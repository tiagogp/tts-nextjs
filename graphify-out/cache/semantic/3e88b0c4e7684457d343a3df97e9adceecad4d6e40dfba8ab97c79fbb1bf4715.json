{"nodes": [{"id": "_claude_skills_graphify_skill_graphify_skill", "label": "Graphify Skill (Claude Code)", "file_type": "document", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graphify_pipeline", "label": "Graphify Build Pipeline", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 1-9", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two-track extraction: deterministic AST for code (free, no API key ever required) plus LLM semantic extraction only for docs/papers/images; a code-only corpus skips semantic extraction entirely, and the host agent itself acts as the LLM when no Gemini key is set."}, {"id": "_claude_skills_graphify_skill_ast_extraction", "label": "Structural AST Extraction", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part A", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_semantic_subagents", "label": "Parallel Semantic Extraction Subagents", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 3 Part B", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All subagents must be dispatched in a single message to run in parallel; subagent_type must be general-purpose because Explore is read-only and silently drops chunk files written to disk."}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cached per-file extraction results are checked before dispatching subagents so only uncached files cost tokens; stale .graphify_cached.json from a prior run is deleted so Part C never merges it (#1392)."}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection and Labeling", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Steps 4-5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only diagnostic run before labeling that surfaces edge collapse, dangling/missing endpoints, and self-loops \u2014 the silent-corruption modes of incremental updates and AST/LLM id mismatches; it warns but never aborts."}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Graphify Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "## Honesty Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge (use AMBIGUOUS when unsure), always show token cost, show raw cohesion scores, warn before visualizing more than 5000 nodes \u2014 the audit trail is the product."}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Shrink Guard (#479)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json refuses to write when the new graph is smaller than the existing graph.json, and the empty-graph guard checks immediately after build, so an empty or partial extraction never clobbers a good graph, report, or analysis sidecar (#1392)."}, {"id": "_claude_skills_graphify_skill_fast_path_query", "label": "Fast Path: Query Existing Graph", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "## What You Must Do When Invoked", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json exists and the request is a natural-language question, skip the entire build pipeline and run graphify query immediately \u2014 the graph is already built."}, {"id": "_claude_skills_graphify_skill_cost_tracker", "label": "Cumulative Cost Tracker", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 9", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_references_add_watch_add_and_watch", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "see references/add-watch.md", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_references_exports_export_formats", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "See references/exports.md", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_references_extraction_spec_subagent_prompt", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "See references/extraction-spec.md", "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify_skill", "target": "_claude_skills_graphify_references_github_and_merge_clone_and_merge", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "