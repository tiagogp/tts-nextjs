{"nodes": [{"id": "docs_w5_validation_protocol_protocol", "label": "W5 Validation Protocol", "file_type": "document", "source_file": "docs/w5-validation-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "System of record for the W5 first-run round: validate whether a fresh ICP user completes the core loop, understands why it's useful, and shows a real return signal without coaching. 5-session smoke test, 10-session ICP decision round; clean installs must clear localStorage and IndexedDB or the W5 readout desyncs."}, {"id": "docs_w5_validation_protocol_gate_metrics", "label": "W5 Gate Metrics (7 Gates)", "file_type": "concept", "source_file": "docs/w5-validation-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Unaided completion \u22656/10, median TTFR <2min, explain-back \u22657/10, D+1 \u226540% / D+7 \u226525%, differentiation \u22653/10 unprompted, paid pain \u22653/10 same answer, replacement \u22653/10. Judge the round, not one noisy session; failure modes route to front-door fixes, positioning work, billing freeze, or research-build status."}, {"id": "docs_w5_validation_protocol_hear_review_fix", "label": "Hear \u2192 Review \u2192 Fix Loop", "file_type": "concept", "source_file": "docs/w5-validation-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The loop under test: curated native clip \u2192 save one phrase \u2192 review \u2192 write one sentence \u2192 correct \u2192 save correction. Never explained before the first run \u2014 the interface must do the work. The guided lesson corrects locally with no AI provider so the loop completes on a clean install."}, {"id": "docs_w5_validation_protocol_event_model", "label": "W5 Event Model", "file_type": "concept", "source_file": "docs/w5-validation-protocol.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Activation events first_run_started..day_7_returned with derived ttfr and dropoff_step; app telemetry may derive some from lower-level activity events (cards_created, cards_reviewed, correction_generated) but W5 notes use the canonical names."}], "edges": [{"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_validation_protocol_gate_metrics", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null, "weight": 1.0}, {"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_validation_protocol_hear_review_fix", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null, "weight": 1.0}, {"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_validation_protocol_event_model", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null, "weight": 1.0}, {"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_recruiting_message_message", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null, "weight": 1.0}, {"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_consent_script_script", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null, "weight": 1.0}, {"source": "docs_w5_validation_protocol_protocol", "target": "docs_w5_moderator_run_sheet_sheet", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/w5-validation-protocol.md", "source_location": null,